<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jinshu.api.dao.TenantConcurrencyQuotaMapper">

    <resultMap id="BaseResultMap" type="com.jinshu.common.entity.TenantConcurrencyQuota">
        <id column="tenant_id" property="tenantId"/>
        <result column="max_concurrent" property="maxConcurrent"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByTenantId" resultMap="BaseResultMap">
        SELECT tenant_id, max_concurrent, enabled, created_at, updated_at
        FROM tenant_concurrency_quota
        WHERE tenant_id = #{tenantId}
          AND enabled = true
        LIMIT 1
    </select>

</mapper>
